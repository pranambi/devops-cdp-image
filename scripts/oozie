#!/bin/bash
set -euo pipefail

JOBS_FILE="/etc/oozie/oozie-jobs.json"

usage() {
  echo "Usage: oozie job -oozie <url> -info|-kill|-suspend|-resume|-rerun <job-id> [-rerun-fail-nodes]"
  exit 1
}

demo_info() {
  local job_id="$1"
  if [ -f "$JOBS_FILE" ]; then
    JOB_ENTRY=$(jq -r --arg id "$job_id" '.[] | select(.job_id == $id)' "$JOBS_FILE")
    if [ -n "$JOB_ENTRY" ]; then
      JOB_USER=$(echo "$JOB_ENTRY" | jq -r '.user')
      JOB_STATUS=$(echo "$JOB_ENTRY" | jq -r '.status')
      JOB_NAME=$(echo "$JOB_ENTRY" | jq -r '.name')
    else
      JOB_USER="oozie"
      JOB_STATUS="RUNNING"
      JOB_NAME="unknown"
    fi
  else
    JOB_USER="oozie"
    JOB_STATUS="RUNNING"
    JOB_NAME="unknown"
  fi
  echo "Job ID : $job_id"
  echo "Name   : $JOB_NAME"
  echo "Status : $JOB_STATUS"
  echo "User   : $JOB_USER"
}

OOZIE_SERVER=""
ACTION=""
JOB_ID=""
RERUN_FAIL_NODES=false

# Parse arguments - same interface as real Oozie CLI
while [[ $# -gt 0 ]]; do
  case $1 in
    job) shift ;;
    -oozie) OOZIE_SERVER="$2"; shift 2 ;;
    -info) ACTION="info"; JOB_ID="$2"; shift 2 ;;
    -kill) ACTION="kill"; JOB_ID="$2"; shift 2 ;;
    -suspend) ACTION="suspend"; JOB_ID="$2"; shift 2 ;;
    -resume) ACTION="resume"; JOB_ID="$2"; shift 2 ;;
    -rerun) ACTION="rerun"; JOB_ID="$2"; shift 2 ;;
    -rerun-fail-nodes) RERUN_FAIL_NODES=true; shift ;;
    *) shift ;;
  esac
done

if [ -z "$JOB_ID" ] || [ -z "$ACTION" ]; then
  usage
fi

OOZIE_URL="${OOZIE_SERVER:-${OOZIE_URL:-}}"

if [ -z "$OOZIE_URL" ]; then
  echo "WARN: No Oozie URL provided — running in demo mode"
  if [ "$ACTION" = "info" ]; then
    demo_info "$JOB_ID"
  else
    echo "job: $JOB_ID $ACTION"
  fi
  exit 0
fi

# info — GET request to fetch job details
if [ "$ACTION" = "info" ]; then
  RESPONSE=$(curl -sf "$OOZIE_URL/v1/job/$JOB_ID?show=info" 2>/dev/null) || true
  if [ -z "$RESPONSE" ]; then
    echo "WARN: Oozie server not reachable at $OOZIE_URL — running in demo mode"
    demo_info "$JOB_ID"
  else
    JOB_USER=$(echo "$RESPONSE" | jq -r '.user // "unknown"')
    JOB_STATUS=$(echo "$RESPONSE" | jq -r '.status // "UNKNOWN"')
    JOB_NAME=$(echo "$RESPONSE" | jq -r '.appName // "unknown"')
    echo "Job ID : $JOB_ID"
    echo "Name   : $JOB_NAME"
    echo "Status : $JOB_STATUS"
    echo "User   : $JOB_USER"
  fi
  exit 0
fi

# Build request URL for job actions
if [ "$ACTION" = "rerun" ] && [ "$RERUN_FAIL_NODES" = true ]; then
  REQUEST_URL="$OOZIE_URL/v1/job/$JOB_ID?action=rerun&reRunFailNodes=true"
else
  REQUEST_URL="$OOZIE_URL/v1/job/$JOB_ID?action=$ACTION"
fi

# Attempt real API call
HTTP_CODE=$(curl -s -o /tmp/oozie_response.json -w "%{http_code}" \
  -X PUT \
  -H "Content-Type: application/json" \
  "$REQUEST_URL" 2>/dev/null) || true

if [ "$HTTP_CODE" = "200" ] || [ "$HTTP_CODE" = "204" ]; then
  echo "job: $JOB_ID $ACTION"
  cat /tmp/oozie_response.json 2>/dev/null || true
elif [ -z "$HTTP_CODE" ] || [ "$HTTP_CODE" = "000" ]; then
  echo "WARN: Oozie server not reachable at $OOZIE_URL — running in demo mode"
  echo "job: $JOB_ID $ACTION"
else
  echo "ERROR: Oozie server returned HTTP $HTTP_CODE"
  cat /tmp/oozie_response.json 2>/dev/null || true
  exit 1
fi
